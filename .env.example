# --- Stage 6 — configuration & policy (copy to `.env`, never commit secrets) ---
# COINGECKO_COIN_ID=solana
# COINGECKO_VS_CURRENCY=usd
# COINGECKO_OHLC_DAYS=1
# TOKEN_MINT=
# QUOTE_MINT=So11111111111111111111111111111111111111112
# RPC_URL — use a private mainnet HTTPS RPC (e.g. Alchemy: https://www.alchemy.com/solana ).
# Public https://api.mainnet-beta.solana.com rate-limits and often blocks headless/browser traffic (403).
# RPC_URL=https://solana-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
# RPC_URL=https://api.mainnet-beta.solana.com
# MODE=paper
#   replay  = offline / backtest only (no on-chain broadcast via SafetyRails)
#   paper   = live data + signals; executeJupiterSwap still blocks broadcast unless MODE=live
#   live    = allow on-chain broadcast when caller uses broadcast:true (review caps first)
# SIGNING_MODE=phantom_ui
#   phantom_ui   = Model A — Phantom / wallet-adapter in a browser UI you host (not bundled here)
#   headless_dev = Model B — SOL_BOT_HEADLESS_SIGNER + SOLANA_SECRET_KEY (dev only)
# Per-leg max for Jupiter (must cover headless signal sizes below). Example: 5_000_000 for 0.005 SOL ceiling + token leg.
# SOL_BOT_MAX_INPUT_RAW=5000000
# SOL_BOT_KILL_SWITCH=0

# --- Stage 5 execution (Model B headless — NEVER commit real secrets) ---
# SOL_BOT_HEADLESS_SIGNER=1
# SOLANA_SECRET_KEY=   # base58 or JSON [..] byte array from solana-keygen
# SOL_BOT_LIVE_JUPITER=1  # enables optional live Jupiter quote vitest

# --- Stage 7 — verification (optional; no secrets) ---
# SOL_BOT_STAGE7_CHAIN_TEST=1   # run devnet (+ optional mainnet) RPC health vitests
# STAGE7_DEVNET_RPC_URL=https://api.devnet.solana.com
# STAGE7_MAINNET_RPC_URL=       # paid RPC recommended; omit to skip mainnet read-only test

# --- Stage 8 — risk & compliance (no secrets; read the doc) ---
# See docs/STAGE8_RISK_AND_COMPLIANCE.md before non-trivial mainnet use.

# --- Headless signal → Jupiter (Node only; see docs/RUNBOOK_SIGNAL_EXEC.md) ---
# SIGNAL_EXEC_ENABLED=1
# SIGNAL_EXEC_POOL_ADDRESS=58oQChx4yWmvKdwLLZzBi4ChoCc2fqCUWBkwMihLYQo2
# SIGNAL_EXEC_BUY_LAMPORTS=1000000
# SIGNAL_EXEC_SELL_TOKEN_RAW=10000
# SIGNAL_EXEC_SIMULATE_ONLY=1
# SIGNAL_EXEC_POLL_MS=60000
# SIGNAL_EXEC_ONCE=0
# Optional localhost dashboard (same machine as the runner): http://127.0.0.1:3847/
# SIGNAL_EXEC_HTTP_PORT=3847
# SIGNAL_EXEC_GECKO_API_BASE=
