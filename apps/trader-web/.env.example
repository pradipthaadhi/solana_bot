# Copy to `apps/trader-web/.env` and adjust. Vite only exposes vars prefixed with `VITE_`.

# Operational mode (matches server `MODE`): default paper — no on-chain broadcast from this UI.
# Set to `live` only when you intentionally want RPC send after turning off "Simulate only".
VITE_MODE=paper

# Optional defaults for the form (mainnet RPC URL, output mint for BUY/SELL pair).
# VITE_RPC_URL=https://api.mainnet-beta.solana.com
# VITE_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Optional safety cap default (bigint string, same semantics as `SOL_BOT_MAX_INPUT_RAW` in repo root `.env`).
# BUY size 0.001 SOL = 1_000_000 lamports — cap must be ≥ that plus any SELL raw cap check.
# VITE_SOL_BOT_MAX_INPUT_RAW=5000000

# `1` or `true` = kill switch always engaged (UI checkbox locked on).
# VITE_SOL_BOT_KILL_SWITCH=0
